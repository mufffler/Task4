<Window x:Class="RacingSimulator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RacingSimulator.ViewModels"
        Title="Reflection Class Loader" Height="650" Width="900" WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F0F0F0" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Путь к библиотеке классов (DLL):" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Rectangle"/>
                <TextBox Grid.Column="1" Text="{Binding DllPath, UpdateSourceTrigger=PropertyChanged}" Padding="5" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Content="Загрузить сборку" Command="{Binding LoadDllCommand}" Width="140" Padding="5" Margin="10,0,0,0" Background="#E1E1E1"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Шаг 1: Найденные классы (IRacingService)" Margin="0,0,5,0">
                <ListBox ItemsSource="{Binding FoundTypes}" SelectedItem="{Binding SelectedType}" DisplayMemberPath="Name" Margin="5"/>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="Шаг 2: Выберите метод класса" Margin="5,0,5,0">
                <ListBox ItemsSource="{Binding Methods}" SelectedItem="{Binding SelectedMethod}" DisplayMemberPath="Name" Margin="5"/>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Шаг 3: Ввод аргументов" Margin="5,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="5">
                            <TextBlock Text="Параметры создания объекта (Конструктор):" FontWeight="Bold" Margin="0,5,0,5" Foreground="DarkBlue"/>
                            <ItemsControl ItemsSource="{Binding ConstructorParameters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding ParameterType.Name, StringFormat='({0})'}" FontSize="10" Foreground="Gray"/>
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Padding="3"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Separator Margin="0,10,0,10"/>

                            <TextBlock Text="Параметры выполнения метода:" FontWeight="Bold" Margin="0,0,0,5" Foreground="DarkGreen"/>
                            <ItemsControl ItemsSource="{Binding MethodParameters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding ParameterType.Name, StringFormat='({0})'}" FontSize="10" Foreground="Gray"/>
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Padding="3"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <Button Grid.Row="1" Content="🚀 Выполнить метод" Command="{Binding ExecuteMethodCommand}" 
                            Height="35" Margin="5" Background="LightGreen" FontWeight="Bold"/>
                </Grid>
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="2" Header="Результат выполнения рефлексии" Margin="0,10,0,0">
            <TextBox Text="{Binding ExecutionResult, Mode=OneWay}" IsReadOnly="True" 
                     Background="#1E1E1E" Foreground="LightGreen" FontFamily="Consolas" FontSize="12" Padding="5" TextWrapping="Wrap"/>
        </GroupBox>
    </Grid>
</Window>